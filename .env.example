# Resend API key for sending emails
RESEND_API_KEY=
# Sender address, e.g. "Mardu <noreply@example.com>"
EMAIL_FROM=
# Recipient address for contact form submissions
EMAIL_TO=

# Google reCAPTCHA keys
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Base URL for generating newsletter confirmation links
APP_URL=
# Secret used to sign newsletter tokens
NEWSLETTER_SECRET=

# Optional path for storing JSON data (defaults to ./data)
DATA_DIR=

# Optional Twenty CRM integration
TWENTY_API_KEY=
TWENTY_API_BASE_URL=https://twenty.mardu.systems/rest
TWENTY_SYNC_TIMEOUT_MS=6000
# Optional custom field keys for contact lead enrichment in Twenty
TWENTY_CONTACT_MESSAGE_FIELD=
TWENTY_CONTACT_SOURCE_FIELD=
TWENTY_CONTACT_NEWSLETTER_OPT_IN_FIELD=

# Payload CMS
DATABASE_URI=
PAYLOAD_SECRET=
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3000

# Payload OIDC SSO (Auth0, Keycloak, Okta, Entra ID)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_REDIRECT_URI=http://localhost:3000/api/sso/callback
# Optional hardening (comma-separated allow-lists)
OIDC_ALLOWED_EMAILS=
OIDC_ALLOWED_EMAIL_DOMAINS=
# Optional auto-provisioning for first login (default: false)
OIDC_AUTO_CREATE_USERS=false
# Optional dedicated signing key for OIDC state/session cookies
OIDC_SESSION_SECRET=
# Optional debugging in development only (ignored in production)
OIDC_DEBUG=false
