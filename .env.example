# Resend API key for sending emails
RESEND_API_KEY=
# Sender address, e.g. "Mardu <noreply@example.com>"
EMAIL_FROM=
# Recipient address for contact form submissions
EMAIL_TO=

# Google reCAPTCHA keys
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Base URL for generating newsletter confirmation links
APP_URL=
# Secret used to sign newsletter tokens
NEWSLETTER_SECRET=

# Optional path for storing JSON data (defaults to ./data)
DATA_DIR=

# Optional Twenty CRM integration
TWENTY_API_KEY=
TWENTY_API_BASE_URL=https://twenty.mardu.systems/rest
TWENTY_SYNC_TIMEOUT_MS=6000
# Optional custom field keys for contact lead enrichment in Twenty
TWENTY_CONTACT_MESSAGE_FIELD=
TWENTY_CONTACT_SOURCE_FIELD=
TWENTY_CONTACT_NEWSLETTER_OPT_IN_FIELD=
